# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secrets — NEVER commit real credentials.
# ANTHROPIC_API_KEY lives here (local only), never in CI. See build_spec.md
# cost guardrails.
.env

# Transient batch handoff between `--mode batch-submit` and `batch-retrieve`.
extraction/cache/pending_batch.json

# Stage 4 DQ gate staging file — promoted to synthesized.jsonl only on pass;
# a leftover means the last run failed the gate. Never committed.
data/curated/*.staging.jsonl

# Stage 6 local training state (regenerable). The committed adapter, metrics,
# and model_registry.json are what the app/CI consume; MLflow's local store and
# the per-epoch checkpoints are intermediate.
mlruns/
training_results/checkpoints/

# OS
.DS_Store
